                            <input type="date" value={filtroFin} onChange={e => setFiltroFin(e.target.value)} className="w-full p-3 bg-slate-50 rounded-xl text-sm border-none focus:ring-2 ring-indigo-500 outline-none" />
                          </div>
                        </div>
                     </div>

