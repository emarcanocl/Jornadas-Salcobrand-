            setJornadas(nuevasJornadas);
            mostrarNotificacion("Jornada guardada exitosamente");
            setEsFeriado(false); setEsDobleTurno(false); setEsLluvia(false);
          };

          const eliminarJornada = (id) => {
            setJornadas(jornadas.filter(j => j.id !== id));
            mostrarNotificacion("Registro eliminado");
          };

          const guardarAjustes = () => {
            setValoresActuales(formAjustes);
            mostrarNotificacion("Nuevas tarifas guardadas");
            setPestanaActiva('registro');
          };

          const exportarCSV = () => {
            if (jornadasFiltradas.length === 0) return mostrarNotificacion("No hay datos", "error");
            const cabeceras = ["Fecha", "Tipo de Dia", "Es Feriado", "Doble Turno", "Bono Lluvia", "Sueldo Base", "Bono Fin de Semana", "Total Feriado", "Total Doble Turno", "Total Lluvia", "Total Generado"];
            
            const filas = jornadasFiltradas.map(j => [
              j.fecha, j.tipoDia, j.esFeriado?"Si":"No", j.esDobleTurno?"Si":"No", j.esLluvia?"Si":"No",
              valoresActuales.BASE, 
              (j.tipoDia === 'Sábado' ? valoresActuales.BONO_SABADO : j.tipoDia === 'Domingo' ? valoresActuales.BONO_DOMINGO : 0),
              j.esFeriado ? valoresActuales.BONO_FERIADO : 0,
              j.esDobleTurno ? valoresActuales.BONO_DOBLE_TURNO : 0,
              j.esLluvia ? valoresActuales.BONO_LLUVIA : 0,
              j.totalGenerado
            ]);
            
            const contenido = [cabeceras.join(";"), ...filas.map(f => f.join(";"))].join("\n");
            const blob = new Blob(["\uFEFF" + contenido], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.setAttribute("download", `Mis_Jornadas_${filtroInicio}_al_${filtroFin}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
          };

          const jornadasFiltradas = useMemo(() => jornadas.filter(j => j.fecha >= filtroInicio && j.fecha <= filtroFin), [jornadas, filtroInicio, filtroFin]);
          const estadisticas = useMemo(() => jornadasFiltradas.reduce((a, c) => ({ dias: a.dias + 1, total: a.total + c.totalGenerado }), { dias: 0, total: 0 }), [jornadasFiltradas]);

          return (
