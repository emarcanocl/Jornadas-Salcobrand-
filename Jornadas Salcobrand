        const { useState, useEffect, useMemo } = React;

        const VALORES_POR_DEFECTO = {
          BASE: 52500, BONO_SABADO: 5000, BONO_DOMINGO: 15000,
          BONO_FERIADO: 15000, BONO_DOBLE_TURNO: 20000, BONO_LLUVIA: 20000,
        };

        const formatearDinero = (monto) => new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(monto || 0);
        const obtenerFechaHoy = () => new Date().toISOString().split('T')[0];

        // --- HOOK MEMORIA LOCAL ---
        function useLocalStorage(key, initialValue) {
          const [storedValue, setStoredValue] = useState(() => {
            try {
              const item = window.localStorage.getItem(key);
              return item ? JSON.parse(item) : initialValue;
            } catch (error) { return initialValue; }
          });

          const setValue = (value) => {
            try {
              const valueToStore = value instanceof Function ? value(storedValue) : value;
              setStoredValue(valueToStore);
              window.localStorage.setItem(key, JSON.stringify(valueToStore));
            } catch (error) { console.error(error); }
          };
          return [storedValue, setValue];
        }

        function App() {
          const [pestanaActiva, setPestanaActiva] = useState('registro');
          const [notificacion, setNotificacion] = useState(null);
          
          const [valoresActuales, setValoresActuales] = useLocalStorage('tarifas_turnos', VALORES_POR_DEFECTO);
          const [jornadas, setJornadas] = useLocalStorage('jornadas_guardadas', []);

          // Estados Formularios
          const [fecha, setFecha] = useState(obtenerFechaHoy());
          const [esFeriado, setEsFeriado] = useState(false);
          const [esDobleTurno, setEsDobleTurno] = useState(false);
          const [esLluvia, setEsLluvia] = useState(false);

          const [filtroInicio, setFiltroInicio] = useState(() => {
            const d = new Date(); d.setDate(1); return d.toISOString().split('T')[0];
          });
          const [filtroFin, setFiltroFin] = useState(obtenerFechaHoy());
          const [formAjustes, setFormAjustes] = useState(valoresActuales);

          const mostrarNotificacion = (mensaje, tipo = "exito") => {
            setNotificacion({ mensaje, tipo });
            setTimeout(() => setNotificacion(null), 3000);
          };

          // Lógica de cálculo (reemplazando guiones para evitar problemas de zona horaria)
          const infoDia = useMemo(() => {
            const d = new Date(fecha.replace(/-/g, '\/'));
            const diaSemana = d.getDay();
            let tipo = 'Hábil', bono = 0;
            if (diaSemana === 6) { tipo = 'Sábado'; bono = Number(valoresActuales.BONO_SABADO) || 0; }
            else if (diaSemana === 0) { tipo = 'Domingo'; bono = Number(valoresActuales.BONO_DOMINGO) || 0; }
            return { tipo, bono };
          }, [fecha, valoresActuales]);

          const calculoActual = useMemo(() => {
            const total = (Number(valoresActuales.BASE) || 0) + infoDia.bono + 
              (esFeriado ? (Number(valoresActuales.BONO_FERIADO) || 0) : 0) + 
              (esDobleTurno ? (Number(valoresActuales.BONO_DOBLE_TURNO) || 0) : 0) + 
              (esLluvia ? (Number(valoresActuales.BONO_LLUVIA) || 0) : 0);
            return { total };
          }, [infoDia, esFeriado, esDobleTurno, esLluvia, valoresActuales]);

          const guardarJornada = () => {
            if (jornadas.some(j => j.fecha === fecha)) return mostrarNotificacion("Ya hay un registro en esta fecha", "error");
