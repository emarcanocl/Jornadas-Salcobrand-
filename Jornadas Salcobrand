                  </div>
                </div>
              </header>

              {notificacion && (
                <div className={`fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-full shadow-2xl text-white font-medium flex items-center gap-2 ${notificacion.tipo === 'error' ? 'bg-red-500' : 'bg-emerald-500'}`}>
                  <i className={`fa-solid ${notificacion.tipo === 'error' ? 'fa-circle-xmark' : 'fa-circle-check'}`}></i>
                  {notificacion.mensaje}
                </div>
              )}

              <main className="max-w-md mx-auto p-4 space-y-6">
                
