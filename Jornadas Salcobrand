                        <h2 className="font-bold">Nuevo Registro</h2>
                      </div>

                      <input type="date" value={fecha} onChange={e => setFecha(e.target.value)} className="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl text-lg font-medium focus:ring-2 ring-indigo-500 outline-none transition-all" />
                      <div className="bg-indigo-50 p-3 rounded-xl text-indigo-700 text-sm font-semibold inline-flex items-center gap-2">
                         Día detectado: {infoDia.tipo} 
                         {infoDia.bono > 0 && <span className="bg-indigo-200 text-indigo-800 px-2 py-0.5 rounded text-xs">+ {formatearDinero(infoDia.bono)}</span>}
                      </div>
                      
                      <div className="grid grid-cols-1 gap-3 pt-2">
                        {[ 
                          { id: 'feriado', label: 'Feriado', state: esFeriado, set: setEsFeriado, icon: "fa-sun", color: "text-orange-500", monto: valoresActuales.BONO_FERIADO },
                          { id: 'doble', label: 'Doble Turno', state: esDobleTurno, set: setEsDobleTurno, icon: "fa-dollar-sign", color: "text-emerald-500", monto: valoresActuales.BONO_DOBLE_TURNO },
                          { id: 'lluvia', label: 'Bono Lluvia', state: esLluvia, set: setEsLluvia, icon: "fa-cloud-showers-heavy", color: "text-blue-500", monto: valoresActuales.BONO_LLUVIA }
                        ].map(item => (
                          <label key={item.id} className={`flex items-center justify-between p-4 rounded-2xl border-2 transition-all cursor-pointer ${item.state ? 'border-indigo-500 bg-indigo-50/30' : 'border-slate-100 bg-white hover:border-slate-200'}`}>
                            {/* AQUÍ ESTÁ LA CORRECCIÓN CRUCIAL: EL MOTOR INVISIBLE */}
                            <input 
